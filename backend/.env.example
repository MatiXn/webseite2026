# ═══════════════════════════════════════════════════════════════════
# PHE ATS Backend — Environment Variables
# WICHTIG: Niemals echte Werte committen! Nur dieses Template committen.
# Setup: cp .env.example .env  → Werte eintragen
# ═══════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────
APP_ENV=development
# 32-Byte zufälliger Key: openssl rand -hex 32
APP_SECRET_KEY=CHANGE_ME_32_RANDOM_BYTES_HERE
DEBUG=false

# ── CORS — nur diese Domains dürfen den API ansprechen ─────────────
ALLOWED_ORIGINS=https://phe-perm.de,https://www.phe-perm.de

# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
SUPABASE_ANON_KEY=eyJ...anon_key_aus_settings_api
# SERVICE KEY hat volle DB-Rechte — niemals ans Frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key_aus_settings_api
# Settings → API → JWT Secret
SUPABASE_JWT_SECRET=DEIN_JWT_SECRET_AUS_SUPABASE_DASHBOARD

# ── Rate Limiting ──────────────────────────────────────────────────
# Leer lassen = in-memory (nur für 1 Instance). Redis für Multi-Instance.
REDIS_URL=

# ── Sentry Error Tracking ──────────────────────────────────────────
SENTRY_DSN=https://KEY@oXXXX.ingest.sentry.io/PROJEKT_ID

# ── File Upload ────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_BUCKET=candidate-documents

# ── Session ────────────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30

# ── Cloud Run (wird von GCP automatisch gesetzt) ───────────────────
# PORT=8080
